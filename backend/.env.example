# Turso 云数据库配置（部署到 Render 时必填）
# 在 https://turso.tech 创建数据库后填入
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-turso-token-here

# JWT 密钥（部署时请改为强随机字符串）
JWT_SECRET=please-change-me-in-production

# 线上前端地址（用于 CORS）
FRONTEND_URL=https://your-app.vercel.app

# 服务端口（Render 会自动注入 PORT）
PORT=3000
